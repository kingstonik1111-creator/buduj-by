# ── BUDUJ.BY · заголовки безопасности и кэш (для hoster.by / Apache/LiteSpeed) ──
# Заменяет файл _headers (формат Cloudflare, на белорусском хостинге не работает)

# Принудительный HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# Заголовки безопасности
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Кэширование
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML — не кэшировать (всегда свежая версия)
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # Статика — кэш на 30 дней
  <FilesMatch "\.(svg|jpg|jpeg|png|ico|webp|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # sitemap и robots — на сутки
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# Кодировка по умолчанию
AddDefaultCharset UTF-8
